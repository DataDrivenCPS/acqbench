    s223:connectedThrough wbs:conn-chlorination-to-static-mixer,
        wbs:conn-static-mixer-to-storage-tank-1 ;
    s223:connectedTo wbs:storage-tank-1 ;
    s223:hasConnectionPoint wbs:static-mixer-in,
        wbs:static-mixer-out ;
    rdfs:comment "WaterTAP: fs.pretreatment.static_mixer (StaticMixerZO)" ;
    nawi:hasProcess nawi:Process-Mixing .

wbs:storage-tank-1 a nawi:Tank ;
    rdfs:label "Storage Tank 1" ;
    s223:cnx wbs:storage-tank-1-in,
        wbs:storage-tank-1-out ;
    s223:connected wbs:media-filtration,
        wbs:static-mixer ;
    s223:connectedFrom wbs:static-mixer ;
    s223:connectedThrough wbs:conn-static-mixer-to-storage-tank-1,
        wbs:conn-storage-tank-1-to-media-filtration ;
    s223:connectedTo wbs:media-filtration ;
    s223:hasConnectionPoint wbs:storage-tank-1-in,
        wbs:storage-tank-1-out ;
    s223:hasRole nawi:Role-Storage ;
    rdfs:comment "WaterTAP: fs.pretreatment.storage_tank_1 (StorageTankZO)" .

wbs:storage-tank-2 a nawi:Tank ;
    rdfs:label "Storage Tank 2" ;
    s223:cnx wbs:storage-tank-2-in,
        wbs:storage-tank-2-out ;
    s223:connected wbs:RO,
        wbs:uv-aop ;
    s223:connectedFrom wbs:RO ;
    s223:connectedThrough wbs:conn-RO-to-storage-tank-2,
        wbs:conn-storage-tank-2-to-uv-aop ;
    s223:connectedTo wbs:uv-aop ;
    s223:hasConnectionPoint wbs:storage-tank-2-in,
        wbs:storage-tank-2-out ;
    s223:hasRole nawi:Role-Storage ;
    rdfs:comment "WaterTAP: fs.posttreatment.storage_tank_2 (StorageTankZO)" .

wbs:uv-aop a nawi:UltravioletLightUnit ;
    rdfs:label "UV/AOP" ;
    s223:cnx wbs:uv-aop-in,
        wbs:uv-aop-out ;
    s223:connected wbs:co2-addition,
        wbs:storage-tank-2 ;
    s223:connectedFrom wbs:storage-tank-2 ;
    s223:connectedThrough wbs:conn-storage-tank-2-to-uv-aop,
        wbs:conn-uv-aop-to-co2-addition ;
    s223:connectedTo wbs:co2-addition ;
    s223:hasConnectionPoint wbs:uv-aop-in,
        wbs:uv-aop-out ;
    rdfs:comment "WaterTAP: fs.posttreatment.uv_aop (UVAOPZO, hydrogen_peroxide)" ;
    nawi:hasProcess nawi:Process-UVDisinfection .

wbs:P1 a nawi:Pump ;
    rdfs:label "High-pressure Pump P1" ;
    s223:cnx wbs:P1-in,
        wbs:P1-out ;
    s223:connected wbs:M1,
        wbs:S1 ;
    s223:connectedFrom wbs:S1 ;
    s223:connectedThrough wbs:conn-P1-to-M1,
        wbs:conn-S1-to-P1 ;
    s223:connectedTo wbs:M1 ;
    s223:hasConnectionPoint wbs:P1-in,
        wbs:P1-out ;
    s223:hasProperty wbs:P1-efficiency,
        wbs:P1-mechanical-power ;
    rdfs:comment "WaterTAP: fs.desalination.P1 (Pump)" .

wbs:P2 a nawi:Pump ;
    rdfs:label "Booster Pump P2" ;
    s223:cnx wbs:P2-in,
        wbs:P2-out ;
    s223:connected wbs:M1,
        wbs:PXR ;
    s223:connectedFrom wbs:PXR ;
    s223:connectedThrough wbs:conn-P2-to-M1,
        wbs:conn-PXR-to-P2 ;
    s223:connectedTo wbs:M1 ;
    s223:hasConnectionPoint wbs:P2-in,
        wbs:P2-out ;
    s223:hasProperty wbs:P2-efficiency,
        wbs:P2-mechanical-power ;
    rdfs:comment "WaterTAP: fs.desalination.P2 (Pump)" .

wbs:M1 a s223:Junction ;
    s223:cnx wbs:M1-inlet-cp,
        wbs:M1-inlet-cp-2,
        wbs:M1-outlet-cp ;
    s223:connected wbs:P1,
        wbs:P2,
        wbs:RO ;
    s223:connectedFrom wbs:P1,
        wbs:P2 ;
    s223:connectedThrough wbs:conn-M1-to-RO,
        wbs:conn-P1-to-M1,
        wbs:conn-P2-to-M1 ;
    s223:connectedTo wbs:RO ;
    s223:hasConnectionPoint wbs:M1-inlet-cp,
        wbs:M1-inlet-cp-2,
        wbs:M1-outlet-cp ;
    s223:hasMedium nawi:Water-Seawater .

wbs:S1 a s223:Junction ;
    s223:cnx wbs:S1-inlet-cp,
        wbs:S1-outlet-cp,
        wbs:S1-outlet-cp-2 ;
    s223:connected wbs:P1,
        wbs:PXR,
        wbs:cartridge-filtration ;
    s223:connectedFrom wbs:cartridge-filtration ;
    s223:connectedThrough wbs:conn-S1-to-P1,
        wbs:conn-S1-to-PXR,
        wbs:conn-cartridge-filtration-to-S1 ;
    s223:connectedTo wbs:P1,
        wbs:PXR ;
    s223:hasConnectionPoint wbs:S1-inlet-cp,
        wbs:S1-outlet-cp,
        wbs:S1-outlet-cp-2 ;
    s223:hasMedium nawi:Water-Seawater .

wbs:media-filtration a nawi:Filter ;
    rdfs:label "Media Filtration" ;
    s223:cnx wbs:media-filtration-in,
        wbs:media-filtration-out,
        wbs:media-filtration-outlet-cp ;
    s223:connected wbs:anti-scalant-addition,
        wbs:backwash-handling,
        wbs:storage-tank-1 ;
    s223:connectedFrom wbs:storage-tank-1 ;
    s223:connectedThrough wbs:conn-media-filtration-to-anti-scalant-addition,
        wbs:conn-media-filtration-to-backwash-handling,
        wbs:conn-storage-tank-1-to-media-filtration ;
    s223:connectedTo wbs:anti-scalant-addition,
        wbs:backwash-handling ;
    s223:hasConnectionPoint wbs:media-filtration-in,
        wbs:media-filtration-out,
        wbs:media-filtration-outlet-cp ;
    rdfs:comment "WaterTAP: fs.pretreatment.media_filtration (MediaFiltrationZO); out = treated, extra outlet = backwash byproduct" ;
    nawi:hasProcess nawi:Process-Filtration .

wbs:RO a nawi:ReverseOsmosisMembrane ;
    rdfs:label "Reverse Osmosis Stage" ;
    s223:cnx wbs:RO-in,
        wbs:RO-out,
        wbs:RO-out-retentate ;
    s223:connected wbs:M1,
        wbs:PXR,
        wbs:storage-tank-2 ;
    s223:connectedFrom wbs:M1 ;
    s223:connectedThrough wbs:conn-M1-to-RO,
        wbs:conn-RO-to-PXR,
        wbs:conn-RO-to-storage-tank-2 ;
    s223:connectedTo wbs:PXR,
        wbs:storage-tank-2 ;
    s223:hasConnectionPoint wbs:RO-in,
        wbs:RO-out,
        wbs:RO-out-retentate ;
    s223:hasProperty wbs:RO-membrane-area ;
    rdfs:comment "WaterTAP: fs.desalination.RO (ReverseOsmosis0D); out = permeate, out-retentate = concentrate" ;
    nawi:hasProcess nawi:Process-ReverseOsmosis .

wbs:PXR a nawi:PressureExchanger ;
    rdfs:label "Pressure Exchanger" ;
    s223:cnx wbs:PXR-brine-in,
        wbs:PXR-brine-out,
        wbs:PXR-in,
        wbs:PXR-out ;
    s223:connected wbs:P2,
        wbs:RO,
        wbs:S1 ;
    s223:connectedFrom wbs:RO,
        wbs:S1 ;
    s223:connectedThrough wbs:conn-PXR-to-P2,
        wbs:conn-RO-to-PXR,
        wbs:conn-S1-to-PXR ;
    s223:connectedTo wbs:P2 ;
    s223:hasConnectionPoint wbs:PXR-brine-in,
        wbs:PXR-brine-out,
        wbs:PXR-in,
        wbs:PXR-out ;
    s223:hasProperty wbs:PXR-efficiency ;
    rdfs:comment "WaterTAP: fs.desalination.PXR (PressureExchanger); in/out = feed side, brine-in/brine-out = brine side" .

