@prefix nawi: <urn:nawi-water-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix s223: <http://data.ashrae.org/standard223#> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix wbs: <urn:swro/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

wbs: a owl:Ontology ;
    owl:imports nawi: .

wbs:P1-efficiency-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:P1 ;
    s223:observes wbs:P1-efficiency ;
    qudt:isDeltaQuantity false .

wbs:P1-mechanical-power-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:P1 ;
    s223:observes wbs:P1-mechanical-power ;
    qudt:isDeltaQuantity false .

wbs:P1-out-pressure-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:P1-out ;
    s223:observes wbs:P1-out-pressure ;
    qudt:isDeltaQuantity false .

wbs:P2-efficiency-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:P2 ;
    s223:observes wbs:P2-efficiency ;
    qudt:isDeltaQuantity false .

wbs:P2-mechanical-power-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:P2 ;
    s223:observes wbs:P2-mechanical-power ;
    qudt:isDeltaQuantity false .

wbs:PXR-brine-out-flow-mass-tds-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:PXR-brine-out ;
    s223:observes wbs:PXR-brine-out-flow-mass-tds ;
    qudt:isDeltaQuantity false .

wbs:PXR-brine-out-flow-mass-water-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:PXR-brine-out ;
    s223:observes wbs:PXR-brine-out-flow-mass-water ;
    qudt:isDeltaQuantity false .

wbs:PXR-brine-out-pressure-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:PXR-brine-out ;
    s223:observes wbs:PXR-brine-out-pressure ;
    qudt:isDeltaQuantity false .

wbs:PXR-brine-out-tds-concentration-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:PXR-brine-out ;
    s223:observes wbs:PXR-brine-out-tds-concentration ;
    qudt:isDeltaQuantity false .

wbs:PXR-efficiency-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:PXR ;
    s223:observes wbs:PXR-efficiency ;
    qudt:isDeltaQuantity false .

wbs:RO-in-flow-mass-tds-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:RO-in ;
    s223:observes wbs:RO-in-flow-mass-tds ;
    qudt:isDeltaQuantity false .

wbs:RO-in-flow-mass-water-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:RO-in ;
    s223:observes wbs:RO-in-flow-mass-water ;
    qudt:isDeltaQuantity false .

wbs:RO-in-pressure-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:RO-in ;
    s223:observes wbs:RO-in-pressure ;
    qudt:isDeltaQuantity false .

wbs:RO-in-temperature-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:RO-in ;
    s223:observes wbs:RO-in-temperature ;
    qudt:isDeltaQuantity false .

wbs:RO-membrane-area-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:RO ;
    s223:observes wbs:RO-membrane-area ;
    qudt:isDeltaQuantity false .

wbs:RO-out-flow-mass-tds-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:RO-out ;
    s223:observes wbs:RO-out-flow-mass-tds ;
    qudt:isDeltaQuantity false .

wbs:RO-out-flow-mass-water-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:RO-out ;
    s223:observes wbs:RO-out-flow-mass-water ;
    qudt:isDeltaQuantity false .

wbs:RO-out-pressure-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:RO-out ;
    s223:observes wbs:RO-out-pressure ;
    qudt:isDeltaQuantity false .

wbs:RO-out-retentate-flow-mass-tds-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:RO-out-retentate ;
    s223:observes wbs:RO-out-retentate-flow-mass-tds ;
    qudt:isDeltaQuantity false .

wbs:RO-out-retentate-flow-mass-water-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:RO-out-retentate ;
    s223:observes wbs:RO-out-retentate-flow-mass-water ;
    qudt:isDeltaQuantity false .

wbs:RO-out-retentate-pressure-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:RO-out-retentate ;
    s223:observes wbs:RO-out-retentate-pressure ;
    qudt:isDeltaQuantity false .

wbs:conn-cartridge-filtration-to-S1-flow-mass-tds-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:conn-cartridge-filtration-to-S1 ;
    s223:observes wbs:conn-cartridge-filtration-to-S1-flow-mass-tds ;
    qudt:isDeltaQuantity false .

wbs:conn-cartridge-filtration-to-S1-flow-mass-water-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:conn-cartridge-filtration-to-S1 ;
    s223:observes wbs:conn-cartridge-filtration-to-S1-flow-mass-water ;
    qudt:isDeltaQuantity false .

wbs:conn-cartridge-filtration-to-S1-pressure-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:conn-cartridge-filtration-to-S1 ;
    s223:observes wbs:conn-cartridge-filtration-to-S1-pressure ;
    qudt:isDeltaQuantity false .

wbs:conn-cartridge-filtration-to-S1-temperature-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:conn-cartridge-filtration-to-S1 ;
    s223:observes wbs:conn-cartridge-filtration-to-S1-temperature ;
    qudt:isDeltaQuantity false .

wbs:intake-in-flow-rate-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:intake-in ;
    s223:observes wbs:intake-in-flow-rate ;
    qudt:isDeltaQuantity false .

wbs:intake-in-tds-concentration-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:intake-in ;
    s223:observes wbs:intake-in-tds-concentration ;
    qudt:isDeltaQuantity false .

wbs:intake-in-tss-concentration-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:intake-in ;
    s223:observes wbs:intake-in-tss-concentration ;
    qudt:isDeltaQuantity false .

wbs:intake-in-toc-concentration-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:intake-in ;
    s223:observes wbs:intake-in-toc-concentration ;
    qudt:isDeltaQuantity false .

wbs:cartridge-filtration-out-toc-concentration-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:cartridge-filtration-out ;
    s223:observes wbs:cartridge-filtration-out-toc-concentration ;
    qudt:isDeltaQuantity false .

wbs:seawater-ro-plant a s223:System ;
    s223:hasBoundaryConnectionPoint wbs:PXR-brine-out,
        wbs:backwash-handling-out,
        wbs:intake-in,
        wbs:storage-tank-3-out ;
    s223:hasMember wbs:desalination-system,
        wbs:posttreatment-system,
        wbs:pretreatment-system .

wbs:storage-tank-3-out-flow-rate-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:storage-tank-3-out ;
    s223:observes wbs:storage-tank-3-out-flow-rate ;
    qudt:isDeltaQuantity false .

wbs:storage-tank-3-out-tds-concentration-sensor a s223:Sensor ;
    s223:hasObservationLocation wbs:storage-tank-3-out ;
    s223:observes wbs:storage-tank-3-out-tds-concentration ;
    qudt:isDeltaQuantity false .

wbs:desalination-system a s223:System ;
    s223:hasBoundaryConnectionPoint wbs:PXR-brine-out,
        wbs:RO-out,
        wbs:S1-inlet-cp ;
    s223:hasMember wbs:M1,
        wbs:P1,
        wbs:P2,
        wbs:PXR,
        wbs:RO,
        wbs:S1 .

wbs:posttreatment-system a s223:System ;
    s223:hasBoundaryConnectionPoint wbs:storage-tank-2-in,
        wbs:storage-tank-3-out ;
    s223:hasMember wbs:co2-addition,
        wbs:lime-addition,
        wbs:storage-tank-2,
        wbs:storage-tank-3,
        wbs:uv-aop ;
    s223:hasRole nawi:Role-Posttreatment .

wbs:pretreatment-system a s223:System ;
    s223:hasBoundaryConnectionPoint wbs:backwash-handling-out,
        wbs:cartridge-filtration-out,
        wbs:intake-in ;
    s223:hasMember wbs:anti-scalant-addition,
        wbs:backwash-handling,
        wbs:cartridge-filtration,
        wbs:chlorination,
        wbs:ferric-chloride-addition,
        wbs:intake,
        wbs:media-filtration,
        wbs:static-mixer,
        wbs:storage-tank-1 ;
    s223:hasRole nawi:Role-Pretreatment .

wbs:P1-efficiency a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:Efficiency ;
    qudt:hasUnit unit:UNITLESS .

wbs:P1-mechanical-power a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:Power ;
    qudt:hasUnit unit:W .

wbs:P1-out-pressure a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:Pressure ;
    rdfs:comment "RO operating pressure" .

wbs:P2-efficiency a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:Efficiency ;
    qudt:hasUnit unit:UNITLESS .

wbs:P2-mechanical-power a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:Power ;
    qudt:hasUnit unit:W .

wbs:PXR-brine-out-flow-mass-tds a s223:QuantifiableObservableProperty ;
    s223:ofMedium nawi:Water-Brine ;
    s223:ofSubstance nawi:Constituent-Salt ;
    qudt:hasQuantityKind qudtqk:MassFlowRate ;
    qudt:hasUnit unit:KiloGM-PER-SEC .

wbs:PXR-brine-out-flow-mass-water a s223:QuantifiableObservableProperty ;
    s223:ofMedium s223:Fluid-Water ;
    qudt:hasQuantityKind qudtqk:MassFlowRate ;
    qudt:hasUnit unit:KiloGM-PER-SEC .

wbs:PXR-brine-out-pressure a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:Pressure .

wbs:PXR-brine-out-tds-concentration a s223:QuantifiableObservableProperty ;
    s223:ofMedium nawi:Water-Brine ;
    s223:ofSubstance nawi:Constituent-Salt ;
    qudt:hasQuantityKind qudtqk:MassConcentration ;
    qudt:hasUnit unit:KiloGM-PER-M3 ;
    rdfs:comment "brine discharge TDS concentration (Ocean Plan III.M.3 effluent salinity)" .

wbs:PXR-efficiency a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:Efficiency ;
    qudt:hasUnit unit:UNITLESS .

wbs:RO-in-flow-mass-tds a s223:QuantifiableObservableProperty ;
    s223:ofMedium nawi:Water-Seawater ;
    s223:ofSubstance nawi:Constituent-Salt ;
    qudt:hasQuantityKind qudtqk:MassFlowRate ;
    qudt:hasUnit unit:KiloGM-PER-SEC .

wbs:RO-in-flow-mass-water a s223:QuantifiableObservableProperty ;
    s223:ofMedium nawi:Water-Seawater ;
    qudt:hasQuantityKind qudtqk:MassFlowRate ;
    qudt:hasUnit unit:KiloGM-PER-SEC .

wbs:RO-in-pressure a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:Pressure .

wbs:RO-in-temperature a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:Temperature .

wbs:RO-membrane-area a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:Area ;
    qudt:hasUnit unit:M2 .

wbs:RO-out-flow-mass-tds a s223:QuantifiableObservableProperty ;
    s223:ofMedium s223:Fluid-Water ;
    s223:ofSubstance nawi:Constituent-Salt ;
    qudt:hasQuantityKind qudtqk:MassFlowRate ;
    qudt:hasUnit unit:KiloGM-PER-SEC .

wbs:RO-out-flow-mass-water a s223:QuantifiableObservableProperty ;
    s223:ofMedium s223:Fluid-Water ;
    qudt:hasQuantityKind qudtqk:MassFlowRate ;
    qudt:hasUnit unit:KiloGM-PER-SEC .

wbs:RO-out-pressure a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:Pressure .

wbs:RO-out-retentate-flow-mass-tds a s223:QuantifiableObservableProperty ;
    s223:ofMedium nawi:Water-Brine ;
    s223:ofSubstance nawi:Constituent-Salt ;
    qudt:hasQuantityKind qudtqk:MassFlowRate ;
    qudt:hasUnit unit:KiloGM-PER-SEC .

wbs:RO-out-retentate-flow-mass-water a s223:QuantifiableObservableProperty ;
    s223:ofMedium s223:Fluid-Water ;
    qudt:hasQuantityKind qudtqk:MassFlowRate ;
    qudt:hasUnit unit:KiloGM-PER-SEC .

wbs:RO-out-retentate-pressure a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:Pressure .

wbs:conn-cartridge-filtration-to-S1-flow-mass-tds a s223:QuantifiableObservableProperty ;
    s223:ofMedium nawi:Water-Seawater ;
    s223:ofSubstance nawi:Constituent-Salt ;
    qudt:hasQuantityKind qudtqk:MassFlowRate ;
    qudt:hasUnit unit:KiloGM-PER-SEC .

wbs:conn-cartridge-filtration-to-S1-flow-mass-water a s223:QuantifiableObservableProperty ;
    s223:ofMedium nawi:Water-Seawater ;
    qudt:hasQuantityKind qudtqk:MassFlowRate ;
    qudt:hasUnit unit:KiloGM-PER-SEC .

wbs:conn-cartridge-filtration-to-S1-pressure a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:Pressure .

wbs:conn-cartridge-filtration-to-S1-temperature a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:Temperature .

wbs:intake-in-flow-rate a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:VolumeFlowRate ;
    rdfs:comment "feed volumetric flow" .

wbs:intake-in-tds-concentration a s223:QuantifiableObservableProperty ;
    s223:ofMedium nawi:Water-Seawater ;
    s223:ofSubstance nawi:Constituent-Salt ;
    qudt:hasQuantityKind qudtqk:MassConcentration ;
    qudt:hasUnit unit:KiloGM-PER-M3 ;
    rdfs:comment "feed TDS concentration" .

wbs:intake-in-tss-concentration a s223:QuantifiableObservableProperty ;
    s223:ofMedium nawi:Water-Seawater ;
    s223:ofSubstance nawi:Constituent-SuspendedSolids ;
    qudt:hasQuantityKind qudtqk:Density ;
    qudt:hasUnit unit:MilliGM-PER-L ;
    rdfs:comment "feed TSS concentration" .

wbs:intake-in-toc-concentration a s223:QuantifiableObservableProperty ;
    s223:ofMedium nawi:Water-Seawater ;
    qudt:hasQuantityKind qudtqk:MassConcentration ;
    qudt:hasUnit unit:KiloGM-PER-M3 ;
    rdfs:comment "feed TOC (nonvolatile organic carbon) concentration" .

wbs:cartridge-filtration-out-toc-concentration a s223:QuantifiableObservableProperty ;
    s223:ofMedium nawi:Water-Seawater ;
    qudt:hasQuantityKind qudtqk:MassConcentration ;
    qudt:hasUnit unit:KiloGM-PER-M3 ;
    rdfs:comment "pretreatment-effluent TOC concentration (after cartridge filtration)" .

wbs:storage-tank-3-out-flow-rate a s223:QuantifiableObservableProperty ;
    qudt:hasQuantityKind qudtqk:VolumeFlowRate ;
    rdfs:comment "product volumetric flow" .

wbs:storage-tank-3-out-tds-concentration a s223:QuantifiableObservableProperty ;
    s223:ofMedium s223:Fluid-Water ;
    s223:ofSubstance nawi:Constituent-Salt ;
    qudt:hasQuantityKind qudtqk:MassConcentration ;
    qudt:hasUnit unit:KiloGM-PER-M3 ;
    rdfs:comment "product TDS concentration" .

wbs:M1-inlet-cp a s223:InletConnectionPoint ;
    s223:cnx wbs:M1,
        wbs:conn-P1-to-M1 ;
    s223:connectsThrough wbs:conn-P1-to-M1 ;
    s223:hasMedium nawi:Water-Seawater ;
    s223:isConnectionPointOf wbs:M1 .

wbs:M1-inlet-cp-2 a s223:InletConnectionPoint ;
    s223:cnx wbs:M1,
        wbs:conn-P2-to-M1 ;
    s223:connectsThrough wbs:conn-P2-to-M1 ;
    s223:hasMedium nawi:Water-Seawater ;
    s223:isConnectionPointOf wbs:M1 .

wbs:M1-outlet-cp a s223:OutletConnectionPoint ;
    s223:cnx wbs:M1,
        wbs:conn-M1-to-RO ;
    s223:connectsThrough wbs:conn-M1-to-RO ;
    s223:hasMedium nawi:Water-Seawater ;
    s223:isConnectionPointOf wbs:M1 .

wbs:P1-in a s223:InletConnectionPoint ;
    s223:cnx wbs:P1,
        wbs:conn-S1-to-P1 ;
    s223:connectsThrough wbs:conn-S1-to-P1 ;
    s223:hasMedium nawi:Water-Seawater ;
    s223:isConnectionPointOf wbs:P1 .

wbs:P2-in a s223:InletConnectionPoint ;
    s223:cnx wbs:P2,
        wbs:conn-PXR-to-P2 ;
    s223:connectsThrough wbs:conn-PXR-to-P2 ;
    s223:hasMedium nawi:Water-Seawater ;
    s223:isConnectionPointOf wbs:P2 .

wbs:P2-out a s223:OutletConnectionPoint ;
    s223:cnx wbs:P2,
        wbs:conn-P2-to-M1 ;
    s223:connectsThrough wbs:conn-P2-to-M1 ;
    s223:hasMedium nawi:Water-Seawater ;
    s223:isConnectionPointOf wbs:P2 .

wbs:PXR-brine-in a s223:InletConnectionPoint ;
    s223:cnx wbs:PXR,
        wbs:conn-RO-to-PXR ;
    s223:connectsThrough wbs:conn-RO-to-PXR ;
    s223:hasMedium nawi:Water-Brine ;
    s223:isConnectionPointOf wbs:PXR .

wbs:PXR-in a s223:InletConnectionPoint ;
    s223:cnx wbs:PXR,
        wbs:conn-S1-to-PXR ;
    s223:connectsThrough wbs:conn-S1-to-PXR ;
    s223:hasMedium nawi:Water-Seawater ;
    s223:isConnectionPointOf wbs:PXR .

wbs:PXR-out a s223:OutletConnectionPoint ;
    s223:cnx wbs:PXR,
        wbs:conn-PXR-to-P2 ;
    s223:connectsThrough wbs:conn-PXR-to-P2 ;
    s223:hasMedium nawi:Water-Seawater ;
    s223:isConnectionPointOf wbs:PXR .

wbs:S1-outlet-cp a s223:OutletConnectionPoint ;
    s223:cnx wbs:S1,
        wbs:conn-S1-to-P1 ;
    s223:connectsThrough wbs:conn-S1-to-P1 ;
    s223:hasMedium nawi:Water-Seawater ;
    s223:isConnectionPointOf wbs:S1 .

wbs:S1-outlet-cp-2 a s223:OutletConnectionPoint ;
    s223:cnx wbs:S1,
        wbs:conn-S1-to-PXR ;
    s223:connectsThrough wbs:conn-S1-to-PXR ;
    s223:hasMedium nawi:Water-Seawater ;
    s223:isConnectionPointOf wbs:S1 .

wbs:anti-scalant-addition-in a s223:InletConnectionPoint ;
    s223:cnx wbs:anti-scalant-addition,
        wbs:conn-media-filtration-to-anti-scalant-addition ;
    s223:connectsThrough wbs:conn-media-filtration-to-anti-scalant-addition ;
    s223:hasMedium nawi:Water-Seawater ;
    s223:isConnectionPointOf wbs:anti-scalant-addition .

wbs:anti-scalant-addition-out a s223:OutletConnectionPoint ;
    s223:cnx wbs:anti-scalant-addition,
        wbs:conn-anti-scalant-addition-to-cartridge-filtration ;
    s223:connectsThrough wbs:conn-anti-scalant-addition-to-cartridge-filtration ;
    s223:hasMedium nawi:Water-Seawater ;
    s223:isConnectionPointOf wbs:anti-scalant-addition .

wbs:backwash-handling-in a s223:InletConnectionPoint ;
    s223:cnx wbs:backwash-handling,
        wbs:conn-media-filtration-to-backwash-handling ;
    s223:connectsThrough wbs:conn-media-filtration-to-backwash-handling ;
    s223:hasMedium nawi:Water-Seawater ;
    s223:isConnectionPointOf wbs:backwash-handling .

wbs:backwash-handling-out a s223:OutletConnectionPoint ;
    s223:hasMedium nawi:Fluid-Sludge ;
    s223:isConnectionPointOf wbs:backwash-handling .

wbs:cartridge-filtration-in a s223:InletConnectionPoint ;
    s223:cnx wbs:cartridge-filtration,
        wbs:conn-anti-scalant-addition-to-cartridge-filtration ;
    s223:connectsThrough wbs:conn-anti-scalant-addition-to-cartridge-filtration ;
    s223:hasMedium nawi:Water-Seawater ;
    s223:isConnectionPointOf wbs:cartridge-filtration .

wbs:chlorination-in a s223:InletConnectionPoint ;
    s223:cnx wbs:chlorination,
        wbs:conn-ferric-chloride-addition-to-chlorination ;
    s223:connectsThrough wbs:conn-ferric-chloride-addition-to-chlorination ;
    s223:hasMedium nawi:Water-Seawater ;
    s223:isConnectionPointOf wbs:chlorination .

wbs:chlorination-out a s223:OutletConnectionPoint ;
    s223:cnx wbs:chlorination,
        wbs:conn-chlorination-to-static-mixer ;
    s223:connectsThrough wbs:conn-chlorination-to-static-mixer ;
    s223:hasMedium nawi:Water-Seawater ;
    s223:isConnectionPointOf wbs:chlorination .

wbs:co2-addition-in a s223:InletConnectionPoint ;
    s223:cnx wbs:co2-addition,
        wbs:conn-uv-aop-to-co2-addition ;
    s223:connectsThrough wbs:conn-uv-aop-to-co2-addition ;
    s223:hasMedium s223:Fluid-Water ;
    s223:isConnectionPointOf wbs:co2-addition .

wbs:co2-addition-out a s223:OutletConnectionPoint ;
    s223:cnx wbs:co2-addition,
        wbs:conn-co2-addition-to-lime-addition ;
    s223:connectsThrough wbs:conn-co2-addition-to-lime-addition ;
    s223:hasMedium s223:Fluid-Water ;
    s223:isConnectionPointOf wbs:co2-addition .

wbs:ferric-chloride-addition-in a s223:InletConnectionPoint ;
    s223:cnx wbs:conn-intake-to-ferric-chloride-addition,
        wbs:ferric-chloride-addition ;
    s223:connectsThrough wbs:conn-intake-to-ferric-chloride-addition ;
    s223:hasMedium nawi:Water-Seawater ;
    s223:isConnectionPointOf wbs:ferric-chloride-addition .

wbs:ferric-chloride-addition-out a s223:OutletConnectionPoint ;
    s223:cnx wbs:conn-ferric-chloride-addition-to-chlorination,
        wbs:ferric-chloride-addition ;
    s223:connectsThrough wbs:conn-ferric-chloride-addition-to-chlorination ;
    s223:hasMedium nawi:Water-Seawater ;
    s223:isConnectionPointOf wbs:ferric-chloride-addition .

wbs:intake-out a s223:OutletConnectionPoint ;
    s223:cnx wbs:conn-intake-to-ferric-chloride-addition,
        wbs:intake ;
    s223:connectsThrough wbs:conn-intake-to-ferric-chloride-addition ;
    s223:hasMedium nawi:Water-Seawater ;
    s223:isConnectionPointOf wbs:intake .

wbs:lime-addition-in a s223:InletConnectionPoint ;
    s223:cnx wbs:conn-co2-addition-to-lime-addition,
        wbs:lime-addition ;
    s223:connectsThrough wbs:conn-co2-addition-to-lime-addition ;
    s223:hasMedium s223:Fluid-Water ;
